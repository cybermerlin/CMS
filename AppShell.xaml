<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="CMS.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:CMS"
    Title="CMS">

    <Shell.ToolbarItems>
        <ToolbarItem
            IconImageSource="dotnet_bot.png"
            Text="Авторизация"
            Order="Primary"
            Priority="0"
            Clicked="OnAuthorizeClicked" />
    </Shell.ToolbarItems>

    <ShellContent
        Title="Discussions"
        ContentTemplate="{DataTemplate local:DiscussionsPage}"
        Route="DiscussionsPage" />

    <ShellContent
        Title="Настройки"
        ContentTemplate="{DataTemplate local:SettingsPage}"
        Route="SettingsPage" />

    <ShellContent
        Title="Home"
        ContentTemplate="{DataTemplate local:MainPage}"
        Route="MainPage" />

</Shell>
