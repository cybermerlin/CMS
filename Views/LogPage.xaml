<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:services="clr-namespace:CMS.Services"
             x:Class="CMS.Views.LogPage"
             x:ClassModifier="internal"
             Title="Log Page">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="20">
            <CollectionView x:Name="LogsCollection" Margin="4">
                <CollectionView.ItemsLayout>
                    <LinearItemsLayout Orientation="Vertical" ItemSpacing="5" />
                </CollectionView.ItemsLayout>
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="services:HttpLogEntry">
                        <VerticalStackLayout Margin="0,4" BackgroundColor="#333333">
                            <HorizontalStackLayout VerticalOptions="Center" Padding="4">
                                <Label Text="{Binding Timestamp, StringFormat='{0:T}'}" FontSize="10" TextColor="Silver" Margin="4" />
                                <Label Text="{Binding Title}" FontAttributes="Bold" />
                            </HorizontalStackLayout>
                            <Editor Text="{Binding Content, Mode=OneWay}"
                                IsReadOnly="True"
                                AutoSize="TextChanges"
                                BackgroundColor="Transparent"
                                Margin="0"
                                FontSize="12"
                                TextColor="Gray"
                                VerticalOptions="Center" />
                        </VerticalStackLayout>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
